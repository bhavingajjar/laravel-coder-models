# Shared LoRA training config — sourced by finetune/local/*, finetune/hf/*, finetune/kaggle/*
BASE_MODEL="${BASE_MODEL:-Qwen/Qwen2.5-Coder-7B-Instruct}"
EPOCHS="${EPOCHS:-1}"
MAX_SEQ_LENGTH="${MAX_SEQ_LENGTH:-1024}"
LORA_R="${LORA_R:-4}"
LORA_ALPHA="${LORA_ALPHA:-8}"

# Local paths (relative to finetune/)
DATA_DIR="${DATA_DIR:-data}"
TRAIN_FILE="${TRAIN_FILE:-data/laravel_train.jsonl}"
EVAL_FILE="${EVAL_FILE:-data/laravel_eval.jsonl}"
ADAPTER_DIR="${ADAPTER_DIR:-qwen2.5-7b-laravel-coder-lora/adapters/qwen-laravel-lora}"

# Hugging Face Hub
DATASET_REPO="${DATASET_REPO:-bhavin-gajjar/laravel-coder-lora-train}"
HUB_MODEL_ID="${HUB_MODEL_ID:-bhavin-gajjar/qwen-laravel-coder}"
HUB_MODEL_ID_OLD="${HUB_MODEL_ID_OLD:-bhavin-gajjar/qwen-laravel-lora}"
BUCKET_ID="${BUCKET_ID:-bhavin-gajjar/mybucket}"
BUCKET_PREFIX="${BUCKET_PREFIX:-laravel-coder-lora-train}"

# Kaggle
KAGGLE_USERNAME="${KAGGLE_USERNAME:-bhavingajjar22}"
KAGGLE_DATASET_SLUG="${KAGGLE_DATASET_SLUG:-laravel-coder-lora-train}"
KAGGLE_MODEL_SLUG="${KAGGLE_MODEL_SLUG:-qwen-laravel-coder}"
KAGGLE_WEIGHTS_SLUG="${KAGGLE_WEIGHTS_SLUG:-qwen-laravel-coder-weights}"
KAGGLE_KERNEL_TRAIN="${KAGGLE_KERNEL_TRAIN:-qwen-laravel-coder-train}"
KAGGLE_KERNEL_INFERENCE="${KAGGLE_KERNEL_INFERENCE:-qwen-laravel-coder-inference}"

# HF Jobs
HF_FLAVOR="${HF_FLAVOR:-a10g-small}"
HF_TIMEOUT="${HF_TIMEOUT:-2h}"

# Python venv inside finetune/
VENV_DIR="${VENV_DIR:-.venv}"
